        <mxCell id="a2" value="GayHydra Engine — one JVM process · whole framework (DD-010/011)&#xa;loaders · auto-analysis · SLEIGH → P-code · C++ decompiler (IPC untouched)&#xa;PROVEN — reused as-is, never rewritten (P1)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fontFamily=Menlo;fillColor=#0c1a12;strokeColor=#55ff99;fontColor=#bfffd9;fontStyle=1;" vertex="1" parent="1">
