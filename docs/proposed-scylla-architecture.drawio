        <mxCell id="title" value="Scylla — Proposed Hexagonal Target  ·  durable Rust core · droppable engine · disposable heads" style="text;html=1;fontSize=20;fontStyle=1;fontColor=#27d4ff;fontFamily=Menlo;align=left;verticalAlign=middle;" vertex="1" parent="1">
